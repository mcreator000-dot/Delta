local api = {}

function api.UpdateKeybinds(name, key, show, active)
    if not key then
        key = "None"
    end

    keyMap[name] = key

    if rowMap[name] then
        local row = rowMap[name]
        local badge = row:FindFirstChildOfClass("TextLabel")
        local label = row
        if badge then
            local children = row:GetChildren()
            for _, child in ipairs(children) do
                if child:IsA("TextLabel") and child ~= row then
                    badge = child
                    break
                end
            end
        end

        row.Visible = show ~= false
        row.TextColor3 = active and Color3.fromRGB(34, 197, 94) or Color3.fromRGB(220, 74, 74)
        row.Text = "   " .. name .. "  -  " .. key .. "  |  " .. (active and "Active" or "Inactive")
        if badge then
            badge.Text = key
        end
    else
        makeRow(name, key, show ~= false, active)
    end

    rowCount = 0
    for _, child in ipairs(rowsFolder:GetChildren()) do
        if child:IsA("TextLabel") and child.Visible then
            child.Position = UDim2.new(0, 4, 0, 18 + (rowCount * 16))
            rowCount += 1
        end
    end
end

api.Visible = visible
api.Disconnect = disconnect

return api
