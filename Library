  tab_title = tab_title or ("Tab " .. tostring(tab_num))
  menu.values[tab_num] = {}
  tab_num = tab_num + 1

  local TabButton = library:create("TextButton", {
    BackgroundColor3 = Color3.fromRGB(8, 12, 18),
    BackgroundTransparency = 0,
    BorderSizePixel = 0,
    ClipsDescendants = true,
    Size = UDim2.new(0, 112, 0, 26),
    Text = "",
    AutoButtonColor = false,
  }, TabButtons)
  local TabButtonCorner = library:create("UICorner", { CornerRadius = UDim.new(0, 10) }, TabButton)

  local TabHighlight = library:create("Frame", {
    Name = "Accent",
    BackgroundColor3 = Color3.fromRGB(52, 149, 255),
    BorderSizePixel = 0,
    Position = UDim2.new(0, 0, 0, 0),
    Size = UDim2.new(0, 4, 1, 0),
    BackgroundTransparency = 1,
  }, TabButton)

  local TabImage = library:create("ImageLabel", {
    AnchorPoint = Vector2.new(0, 0.5),
    BackgroundTransparency = 1,
    Position = UDim2.new(0, 14, 0.5, 0),
    Size = UDim2.new(0, 16, 0, 16),
    Image = tab_image,
    ImageColor3 = Color3.fromRGB(170, 180, 195),
  }, TabButton)

  local TabTitle = library:create("TextLabel", {
    Name = "TabTitle",
    BackgroundTransparency = 1,
    Position = UDim2.new(0, 44, 0, 0),
    Size = UDim2.new(1, -82, 1, 0),
    Font = Enum.Font.GothamSemibold,
    Text = tab_title,
    TextColor3 = Color3.fromRGB(170, 180, 195),
    TextSize = 13,
    TextXAlignment = Enum.TextXAlignment.Left,
  }, TabButton)

  local TabSections = Instance.new("Frame")
  local TabFrames = Instance.new("Frame")
  local Tab = library:create("Frame", { Name = "Tab" .. tab_num, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Visible = false, }, Tabs)
  local TabSections = library:create("Frame", { Name = "TabSections", Parent = Tab, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 24), ClipsDescendants = true, }, Tab)
  local UIListLayout = library:create("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Center, }, TabSections)
  local TabFrames = library:create("Frame", { Name = "TabFrames", BackgroundTransparency = 1, Position = UDim2.new(0, 0, 0, 25), Size = UDim2.new(1, 0, 0, 407), }, Tab)

  if is_first_tab then
    is_first_tab = false
    selected_tab = TabButton
    apply_tab_style(TabButton, true)
    Tab.Visible = true
  end

  TabButton.MouseButton1Down:Connect(function()
    if selected_tab == TabButton then
      return
    end
    for _,TButtons in pairs (TabButtons:GetChildren()) do
      if not TButtons:IsA("TextButton") then
        continue
      end
      apply_tab_style(TButtons, false)
    end
    for _,Tab in pairs (Tabs:GetChildren()) do
      Tab.Visible = false
    end
    Tab.Visible = true
    selected_tab = TabButton
    apply_tab_style(TabButton, true)
  end)

  TabButton.MouseEnter:Connect(function()
    if selected_tab == TabButton then
      return
    end
    TabButton.BackgroundColor3 = Color3.fromRGB(12, 18, 30)
    TabImage.ImageColor3 = Color3.fromRGB(255, 255, 255)
    TabTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
  end)

  TabButton.MouseLeave:Connect(function()
    if selected_tab == TabButton then
      return
    end
    TabButton.BackgroundColor3 = Color3.fromRGB(8, 12, 18)
    TabImage.ImageColor3 = Color3.fromRGB(170, 180, 195)
    TabTitle.TextColor3 = Color3.fromRGB(170, 180, 195)







