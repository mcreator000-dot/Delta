local is_first_tab = true
local selected_tab
local tab_num = 1

local function apply_tab_style(button, active)
  local title = button:FindFirstChild("TabTitle")
  local icon = button:FindFirstChild("ImageLabel")
  local accent = button:FindFirstChild("Accent")
  if active then
    button.BackgroundColor3 = Color3.fromRGB(16, 23, 34)
    if title then
      title.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
    if icon then
      icon.ImageColor3 = Color3.fromRGB(52, 149, 255)
    end
    if accent then
      accent.BackgroundTransparency = 0
    end
  else
    button.BackgroundColor3 = Color3.fromRGB(10, 14, 20)
    if title then
      title.TextColor3 = Color3.fromRGB(170, 180, 195)
    end
    if icon then
      icon.ImageColor3 = Color3.fromRGB(170, 180, 195)
    end
    if accent then
      accent.BackgroundTransparency = 1
    end
  end
end

function menu.new_tab(tab_image, tab_title)
